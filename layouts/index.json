[
  {{ range $index, $page := .Site.RegularPages }}
  {{ if $index }},{{ end }}
  {
    "title": {{ $page.Title | jsonify }},
    "date": {{ $page.Date.Format "2006-01-02T15:04:05Z07:00" | jsonify }},
    "url": {{ $page.RelPermalink | jsonify }},
    "excerpt": {{ $page.Params.excerpt | default "" | jsonify }},
    "type": {{ $page.Params.insight_type | default "article" | jsonify }},
    "featured": {{ $page.Params.featured | default false | jsonify }}
  }
  {{ end }}
]
